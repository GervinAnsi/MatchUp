## Python / Django project .gitignore
## Clean and minimal setup


# Python cache & compiled files
__pycache__/
*.pyc
*.pyo
*.pyd
*$py.class


# Virtual environments
venv/
.venv/
env/
ENV/


# Environment variables
.env
.env.*


# Django specific
# Local database
db.sqlite3
db.sqlite3-journal


# Collected static files
staticfiles/


# Uploaded media files
media/


# Logs
*.log


# IDE / Editor
.vscode/
.idea/


# OS generated files
.DS_Store
Thumbs.db


# Testing / coverage
.coverage
htmlcov/
.pytest_cache/


# Migrations
# Uncomment ONLY if you know what you're doing
# */migrations/*
# !*/migrations/__init__.py